# ============================================
# SMATQ Store Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ===== SERVER CONFIGURATION =====
PORT=5002
NODE_ENV=development

# ===== FRONTEND CONNECTION =====
# For local development: http://localhost:5173
# For Vercel production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# ===== SNIPPE/CLICKPESA PAYMENT CREDENTIALS =====
# Get these from: https://dashboard.clickpesa.com
# REQUIRED: Your app won't work without these!

# Your Snippe/ClickPesa API Key (for authentication)
SNIPPE_API_KEY=your_snippe_api_key_here

# Snippe API Base URL (usually this exact value)
SNIPPE_BASE_URL=https://api.snippe.sh

# Webhook secret for signature verification
# Generate this and add it to your Snippe dashboard webhook settings
SNIPPE_WEBHOOK_SECRET=your_webhook_secret_here

# ===== WEBHOOK URL (for production/Render) =====
# Snippe needs to callback to this URL when payments complete
# For local development: Use ngrok or similar to expose port 5002
# For Render: https://your-app-name.onrender.com/api/webhooks/snippe
WEBHOOK_URL=

# ===== OPTIONAL: DATABASE (for future migration from JSON) =====
# When migrating from JSON files to a real database:
# DATABASE_URL=postgresql://user:password@localhost:5432/smatq_store
